using CommunityToolkit.Maui; // 1. Agrega este using arriba del todo

namespace TrackerObjetos;

public static class MauiProgram
{
    public static MauiApp CreateMauiApp()
    {
        var builder = MauiApp.CreateBuilder();
        builder
            .UseMauiApp<App>()
            .UseMauiCommunityToolkit() // 2. AGREGA ESTA LÍNEA AQUÍ 👈
            .ConfigureMauiHandlers(handlers =>
            {
                handlers.AddHandler(typeof(TrackerObjetos.Controls.CameraPreview), typeof(TrackerObjetos.Platforms.Android.CameraPreviewHandler));
            })
            .ConfigureFonts(fonts =>
            {
                fonts.AddFont("OpenSans-Regular.ttf", "OpenSansRegular");
                fonts.AddFont("OpenSans-Semibold.ttf", "OpenSansSemibold");
            });

        return builder.Build();
    }
}
