using Android.App;
using Android.Content;
using Android.Views;
using Android.Widget;
using Android.Hardware;
using Microsoft.Maui.Handlers;
using Microsoft.Maui.Platform;
using TrackerObjetos.Controls;

namespace TrackerObjetos.Platforms.Android;

public class CameraPreviewHandler : ViewHandler<CameraPreview, FrameLayout>
{
    public CameraPreviewHandler() : base(Microsoft.Maui.Handlers.ViewHandler.ViewMapper)
    {
    }

    protected override FrameLayout CreatePlatformView()
    {
        var context = Application.Context;
        var frame = new FrameLayout(context);

        var surfaceView = new SurfaceView(context);
        frame.AddView(surfaceView, new FrameLayout.LayoutParams(ViewGroup.LayoutParams.MatchParent, ViewGroup.LayoutParams.MatchParent));

        var holder = surfaceView.Holder;
        holder.AddCallback(new CameraSurfaceCallback());

        return frame;
    }

    class CameraSurfaceCallback : Java.Lang.Object, ISurfaceHolderCallback
    {
        Camera _camera;

        public void SurfaceChanged(ISurfaceHolder holder, Format format, int width, int height)
        {
            // no-op
        }

        public void SurfaceCreated(ISurfaceHolder holder)
        {
            try
            {
                _camera = Camera.Open();
                _camera.SetPreviewDisplay(holder);
                _camera.StartPreview();
            }
            catch (System.Exception)
            {
                try { _camera?.Release(); } catch { }
                _camera = null;
            }
        }

        public void SurfaceDestroyed(ISurfaceHolder holder)
        {
            if (_camera != null)
            {
                try
                {
                    _camera.StopPreview();
                }
                catch { }
                try
                {
                    _camera.Release();
                }
                catch { }
                _camera = null;
            }
        }
    }
}
