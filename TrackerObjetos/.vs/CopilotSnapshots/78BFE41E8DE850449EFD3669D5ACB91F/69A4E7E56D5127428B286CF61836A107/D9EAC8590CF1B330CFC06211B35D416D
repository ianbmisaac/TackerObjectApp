<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="TrackerObjetos.MainPage"
             NavigationPage.HasNavigationBar="False">

    <!-- Contenedor principal en capas (Grid) -->
    <Grid RowDefinitions="*">

        <!-- CAPA 1: Vista de la Cámara de fondo -->
        <ContentView x:Name="CamaraPreview"
                     BackgroundColor="Black"
                     HorizontalOptions="FillAndExpand"
                     VerticalOptions="FillAndExpand">
            <!-- Placeholder para la vista de cámara; reemplazar por CameraView del Toolkit cuando esté disponible -->
        </ContentView>

        <!-- CAPA 2: Lienzo transparente para el recuadro del Tracker -->
        <GraphicsView x:Name="TrackerCanvas"
                      InputTransparent="True"
                      HorizontalOptions="FillAndExpand"
                      VerticalOptions="FillAndExpand"/>

        <!-- CAPA 3: Interfaz flotante -->
        <Grid RowDefinitions="Auto, *, Auto" Padding="20">

            <!-- Indicador superior de estado -->
            <Border Grid.Row="0"
                    BackgroundColor="#A6000000"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    Padding="15,8">
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" Color="#00FF66" VerticalOptions="Center"/>
                    <Label Text="IA RASTREADORA ACTIVA" 
                           TextColor="White" 
                           FontSize="12" 
                           FontAttributes="Bold"
                           CharacterSpacing="1.5"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Tarjeta inferior de resultados y botón de Google -->
            <Border Grid.Row="2"
                    BackgroundColor="#F21E1E24" 
                    StrokeShape="RoundRectangle 25"
                    StrokeThickness="1"
                    Stroke="#33FFFFFF"
                    Margin="0,0,0,10"
                    Padding="20,25,20,20">

                <Border.Shadow>
                    <Shadow Brush="#000" Offset="0,10" Radius="15" Opacity="0.5"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="15">

                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="OBJETO EN LA MIRA" 
                               TextColor="#88FFFFFF" 
                               FontSize="10" 
                               HorizontalOptions="Center"
                               CharacterSpacing="1"/>
                        <Label x:Name="LblNombreObjeto" 
                               Text="Apunte a un objeto..." 
                               TextColor="White" 
                               FontSize="22" 
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <BoxView HeightRequest="1" Color="#22FFFFFF" Margin="10,0"/>

                    <Button x:Name="BtnBuscarGoogle"
                            Text="Buscar en Google"
                            Clicked="OnBuscarGoogleClicked"
                            IsEnabled="False"
                            BackgroundColor="#4285F4"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="16"
                            CornerRadius="15"
                            HeightRequest="55">
                        <Button.Triggers>
                            <Trigger TargetType="Button" Property="IsEnabled" Value="False">
                                <Setter Property="BackgroundColor" Value="#554285F4" />
                                <Setter Property="TextColor" Value="#88FFFFFF" />
                            </Trigger>
                        </Button.Triggers>
                    </Button>

                </VerticalStackLayout>
            </Border>

        </Grid>
    </Grid>
</ContentPage>
