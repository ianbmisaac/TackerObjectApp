<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TrackerObjetos.Views.DetalleView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#030615">

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="25">

            <Label Text="OBJETO IDENTIFICADO" 
                   TextColor="#88FFFFFF" 
                   FontSize="11" 
                   CharacterSpacing="1.5"/>

            <Label x:Name="LblTitulo" 
                   TextColor="White" 
                   FontSize="26" 
                   FontAttributes="Bold"/>

            <Border StrokeShape="RoundRectangle 12"
                    StrokeThickness="0"
                    HeightRequest="200"
                    Margin="0,8,0,5">
                <Image x:Name="ObjectImage" 
                       Aspect="AspectFit" />
            </Border>

            <BoxView HeightRequest="1" 
                     Color="#334D4AF2" 
                     Margin="0,5,0,10"/>

            <VerticalStackLayout x:Name="FieldsContainer" Spacing="10">
            </VerticalStackLayout>

            <BoxView HeightRequest="1" 
                     Color="#334D4AF2" 
                     Margin="0,10,0,10"/>

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">

                <Button x:Name="BtnGoogle"
                        Text="Buscar en Google"
                        Clicked="OnGoogleSearchClicked"
                        BackgroundColor="#1A6BEB"
                        TextColor="White"
                        FontSize="13"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        HeightRequest="44"
                        Padding="16,0" />

                <Button Text="Cerrar"
                        Clicked="OnCerrarClicked"
                        BackgroundColor="#4D4AF2"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        HeightRequest="44"
                        Padding="20,0" />

            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
