<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TrackerObjetos.Views.RegisterView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#030615">

    <Grid VerticalOptions="Center" Padding="30">
        <VerticalStackLayout Spacing="15" VerticalOptions="Center">

            <Label Text="Crear cuenta"
                   TextColor="White"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <Border BackgroundColor="#0A0D2E"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="1"
                    Stroke="#334D4AF2"
                    Padding="15,5">
                <Entry x:Name="UsuarioEntry"
                       Placeholder="Usuario"
                       PlaceholderColor="#664D4AF2"
                       TextColor="White"
                       FontSize="16"
                       BackgroundColor="Transparent"/>
            </Border>

            <Border BackgroundColor="#0A0D2E"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="1"
                    Stroke="#334D4AF2"
                    Padding="15,5">
                <Entry x:Name="PasswordEntry"
                       Placeholder="Contraseña"
                       PlaceholderColor="#664D4AF2"
                       TextColor="White"
                       FontSize="16"
                       BackgroundColor="Transparent"
                       IsPassword="True"/>
            </Border>

            <Border BackgroundColor="#0A0D2E"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="1"
                    Stroke="#334D4AF2"
                    Padding="15,5">
                <Entry x:Name="ConfirmEntry"
                       Placeholder="Confirmar contraseña"
                       PlaceholderColor="#664D4AF2"
                       TextColor="White"
                       FontSize="16"
                       BackgroundColor="Transparent"
                       IsPassword="True"/>
            </Border>

            <Button x:Name="BtnRegister"
                    Text="Registrarse"
                    Clicked="OnRegisterClicked"
                    BackgroundColor="#4D4AF2"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="50"
                    Margin="0,10,0,0"/>

            <Label x:Name="LblError"
                   TextColor="#FF4444"
                   FontSize="13"
                   HorizontalOptions="Center"
                   IsVisible="False"/>

        </VerticalStackLayout>
    </Grid>
</ContentPage>
