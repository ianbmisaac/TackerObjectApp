<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TrackerObjetos.Views.AboutView"
             Title="Acerca de">

    <ScrollView>
        <Border BackgroundColor="#F20A0D2E"
                StrokeShape="RoundRectangle 15"
                StrokeThickness="1"
                Stroke="#334D4AF2"
                Margin="20"
                Padding="25">

            <VerticalStackLayout Spacing="15">

                <Label Text="TrackerObjetos"
                       TextColor="White"
                       FontSize="26"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Label Text="v1.0"
                       TextColor="#88FFFFFF"
                       FontSize="14"
                       HorizontalOptions="Center" />

                <BoxView HeightRequest="1" Color="#33FFFFFF" Margin="0,5" />

                <Label Text="Aplicaci&#xF3;n de detecci&#xF3;n de objetos en tiempo real usando ML Kit de Google."
                       TextColor="White"
                       FontSize="14"
                       HorizontalOptions="Start" />

                <Label Text="Tecnolog&#xED;as utilizadas:"
                       TextColor="#88FFFFFF"
                       FontSize="12" />

                <Label Text="&#x2022; .NET 10 MAUI&#x0A;&#x2022; Camera.MAUI&#x0A;&#x2022; ML Kit Object Detection&#x0A;&#x2022; CommunityToolkit.Maui"
                       TextColor="White"
                       FontSize="13"
                       LineHeight="1.6" />

                <BoxView HeightRequest="1" Color="#33FFFFFF" Margin="0,5" />

                <Label Text="Desarrollado con fines educativos."
                       TextColor="#88FFFFFF"
                       FontSize="12"
                       HorizontalOptions="Center" />

            </VerticalStackLayout>
        </Border>
    </ScrollView>

</ContentPage>
