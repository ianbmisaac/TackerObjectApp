<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TrackerObjetos.Views.HistoryView"
             BackgroundColor="#030615"
             Title="Historial">

    <Grid RowDefinitions="*" Padding="15">
        <CollectionView x:Name="HistoryList"
                        SelectionMode="Single"
                        SelectionChanged="OnItemSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#0A0D2E"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="#334D4AF2"
                            Padding="12"
                            Margin="0,5">
                        <Grid ColumnDefinitions="70, *" ColumnSpacing="12">
                            <Border StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    WidthRequest="60"
                                    HeightRequest="60"
                                    VerticalOptions="Center">
                                <Image Source="{Binding ThumbnailSource}"
                                       Aspect="AspectFill"
                                       WidthRequest="60"
                                       HeightRequest="60" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1"
                                                 VerticalOptions="Center"
                                                 Spacing="4">
                                <Label Text="{Binding Titulo}"
                                       TextColor="White"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding DetectedAt, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                       TextColor="#88FFFFFF"
                                       FontSize="12"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="10"
                                     Padding="30">
                    <Label Text="Sin historial"
                           TextColor="#88FFFFFF"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Inicia sesión y detecta objetos para ver tu historial aquí"
                           TextColor="#66FFFFFF"
                           FontSize="13"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
